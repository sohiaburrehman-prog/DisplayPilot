<UserControl x:Class="PrimaryDisplaySwap.Controls.ProfileEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock x:Name="EditorTitle"
                   Text="New profile"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <TextBlock Text="App or launcher (e.g. game.exe or steam.exe)"
                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ProcessNameBox" Grid.Column="0"
                     Style="{StaticResource DarkTextBox}" />
            <ComboBox x:Name="RunningProcessCombo" Grid.Column="1"
                      Style="{StaticResource DarkComboBox}"
                      Width="200" Margin="8,0,0,0"
                      SelectionChanged="RunningProcess_Changed" />
        </Grid>
        <TextBlock Text="Pick from running processes or common launchers. For Steam/Epic/etc., set the game exe below when possible."
                   FontSize="10.5" TextWrapping="Wrap"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="0,0,0,10" />

        <Border x:Name="ResolvedTargetPanel"
                Visibility="Collapsed"
                Background="{StaticResource MapSurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="12,10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Resolve game from launcher (optional but recommended)"
                           FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Match when this exe is running (e.g. eldenring.exe). Without it, only the launcher process triggers the profile."
                           FontSize="10.5" TextWrapping="Wrap"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,8" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ResolvedTargetBox" Grid.Column="0"
                             Style="{StaticResource DarkTextBox}" />
                    <ComboBox x:Name="ResolvedTargetCombo" Grid.Column="1"
                              Style="{StaticResource DarkComboBox}"
                              Width="180" Margin="8,0,0,0"
                              SelectionChanged="ResolvedTarget_Changed" />
                    <Button Grid.Column="2"
                            Content="Suggest running games"
                            Style="{StaticResource MiniButton}"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Click="SuggestRunningGames_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Make this monitor primary"
                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
        <ComboBox x:Name="TargetMonitorCombo"
                  Style="{StaticResource DarkComboBox}"
                  DisplayMemberPath="Label"
                  Margin="0,0,0,12" />

        <CheckBox x:Name="RestoreOnExitCheck"
                  Style="{StaticResource DarkCheckBox}"
                  Content="Restore previous primary when the app exits"
                  IsChecked="True"
                  Margin="0,0,0,8" />

        <CheckBox x:Name="MoveWindowCheck"
                  Style="{StaticResource DarkCheckBox}"
                  Content="Move the game window to the target monitor if it opens elsewhere"
                  IsChecked="True"
                  Margin="0,0,0,4" />
        <TextBlock Text="Fixes games that launch on the old primary before the swap finishes."
                   FontSize="10.5" TextWrapping="Wrap"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="24,0,0,14" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Test profile" Style="{StaticResource MiniButton}"
                    Width="100" Margin="0,0,8,0" Click="TestProfile_Click" />
            <Button Content="Cancel" Style="{StaticResource MiniButton}"
                    Width="92" Click="Cancel_Click" />
            <Button x:Name="SaveProfileButton" Content="Save" Style="{StaticResource AccentMiniButton}"
                    Width="92" Margin="8,0,0,0" Click="Save_Click" />
        </StackPanel>
    </StackPanel>
</UserControl>
