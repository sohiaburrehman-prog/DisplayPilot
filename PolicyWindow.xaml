<Window x:Class="PrimaryDisplaySwap.PolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot"
        Width="520"
        Height="640"
        MinWidth="420"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Text="Policy"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="SubtitleText"
                           Text="DisplayPilot"
                           FontSize="11.5"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,12,16,0"
                Background="{StaticResource MapSurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,14">
                <TextBlock x:Name="BodyText"
                           TextWrapping="Wrap"
                           FontSize="12.5"
                           LineHeight="20"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Padding="16,14,16,16">
            <Button Content="Close"
                    Style="{StaticResource SwapButton}"
                    Height="40"
                    HorizontalAlignment="Stretch"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
