<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ Palette v3 — deep indigo with blue→violet accents.
         Surfaces carry alpha so the acrylic backdrop tints through. ═══════ -->
    <Color x:Key="AccentColor">#4F8DFF</Color>
    <Color x:Key="AccentHoverColor">#74A6FF</Color>
    <Color x:Key="VioletColor">#9D6BFF</Color>
    <Color x:Key="TextPrimaryColor">#F6F8FE</Color>
    <Color x:Key="TextSecondaryColor">#AEB7CC</Color>
    <Color x:Key="TextMutedColor">#7E879C</Color>
    <Color x:Key="SuccessColor">#46E0A0</Color>
    <Color x:Key="ErrorColor">#FF7373</Color>

    <!-- Root flyout surface — indigo gradient, ~88% opaque over acrylic. -->
    <LinearGradientBrush x:Key="FlyoutBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E60C1020" Offset="0" />
        <GradientStop Color="#E6171F38" Offset="1" />
    </LinearGradientBrush>
    <!-- Opaque fallback for systems without the acrylic backdrop. -->
    <LinearGradientBrush x:Key="FlyoutOpaqueBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0C1020" Offset="0" />
        <GradientStop Color="#FF171F38" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="HeaderBrush" Color="#590A0D1A" />
    <SolidColorBrush x:Key="CardBrush" Color="#B31F2536" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="#D92B3349" />
    <SolidColorBrush x:Key="MapSurfaceBrush" Color="#66131829" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#24FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="SwapBrush" Color="#FF9500" />
    <SolidColorBrush x:Key="VioletBrush" Color="{StaticResource VioletColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <!-- Hero gradient: blue → violet. -->
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4F8DFF" Offset="0" />
        <GradientStop Color="#9D6BFF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroGradientHoverBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#74A6FF" Offset="0" />
        <GradientStop Color="#B68BFF" Offset="1" />
    </LinearGradientBrush>
    <!-- Diagonal variant for monitor screens. -->
    <LinearGradientBrush x:Key="ScreenGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#CC4F8DFF" Offset="0" />
        <GradientStop Color="#CC9D6BFF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ScreenIdleBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF262E44" Offset="0" />
        <GradientStop Color="#FF1C2235" Offset="1" />
    </LinearGradientBrush>

    <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- ═══════ Swap button — hero gradient with glow ═══════ -->
    <Style x:Key="SwapButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HeroGradientBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Glow"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Opacity="0.55">
                            <Border.Effect>
                                <BlurEffect Radius="18" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource HeroGradientHoverBrush}" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0.35" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource CardBrush}" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0" />
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Title-bar icon button ═══════ -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="15">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource CardHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Toggle switch — animated knob and track ═══════ -->
    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track"
                            Width="44" Height="24"
                            CornerRadius="12"
                            BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="#272E44" />
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#3C4560" />
                        </Border.BorderBrush>
                        <Ellipse x:Name="Knob"
                                 Width="16" Height="16"
                                 HorizontalAlignment="Left"
                                 Margin="3,0,0,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#AEB7CC" />
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="KnobShift" X="0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="20" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#4F8DFF" Duration="0:0:0.16" />
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#4F8DFF" Duration="0:0:0.16" />
                                        <ColorAnimation Storyboard.TargetName="Knob"
                                                        Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                        To="#FFFFFF" Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#272E44" Duration="0:0:0.16" />
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#3C4560" Duration="0:0:0.16" />
                                        <ColorAnimation Storyboard.TargetName="Knob"
                                                        Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                        To="#AEB7CC" Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Monitor card ═══════ -->
    <Style x:Key="MonitorCard" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,0">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource CardHoverBrush}" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bg" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#4F8DFF" BlurRadius="18" ShadowDepth="0" Opacity="0.25" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
