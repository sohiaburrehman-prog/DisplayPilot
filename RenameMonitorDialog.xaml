<Window x:Class="PrimaryDisplaySwap.RenameMonitorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename monitor"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Border Padding="20">
        <StackPanel>
            <TextBlock x:Name="HardwareNameText"
                       Text="Hardware name"
                       FontSize="12.5"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <TextBlock Text="Nickname"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,4" />
            <TextBox x:Name="NicknameBox"
                     Style="{StaticResource DarkTextBox}"
                     MaxLength="64"
                     Margin="0,0,0,6" />
            <TextBlock Text="Leave blank to use the hardware name."
                       FontSize="10.5"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource MiniButton}"
                        Width="92" IsCancel="True" Click="Cancel_Click" />
                <Button Content="Save" Style="{StaticResource AccentMiniButton}"
                        Width="92" Margin="8,0,0,0" IsDefault="True"
                        Click="Save_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
