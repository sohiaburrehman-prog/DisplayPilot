<Window x:Class="PrimaryDisplaySwap.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True">

    <!-- Borderless flyout. The acrylic system backdrop (set in code-behind)
         shows through the semi-transparent surfaces; DWM rounds the corners
         and draws the shadow on Windows 11. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="-1"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border x:Name="RootSurface"
            Background="{StaticResource FlyoutBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            RenderTransformOrigin="0.5,1">
        <Border.RenderTransform>
            <TranslateTransform x:Name="EntranceShift" Y="0" />
        </Border.RenderTransform>

        <StackPanel>

            <!-- ═══════ Header ═══════ -->
            <Border Background="{StaticResource HeaderBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="18,0,10,0" Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Vector app mark: two monitors -->
                    <Canvas Grid.Column="0" Width="28" Height="28" VerticalAlignment="Center">
                        <Rectangle Canvas.Left="0" Canvas.Top="4" Width="17" Height="12"
                                   RadiusX="2.5" RadiusY="2.5"
                                   Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" />
                        <Rectangle Canvas.Left="11" Canvas.Top="12" Width="17" Height="12"
                                   RadiusX="2.5" RadiusY="2.5"
                                   Fill="#FF10131C"
                                   Stroke="{StaticResource SwapBrush}" StrokeThickness="1.8" />
                    </Canvas>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="13,0,0,0">
                        <TextBlock x:Name="TitleText"
                                   Text="DisplayPilot"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="VersionText"
                                   Text="v1.0"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="10.5"
                                   Margin="8,3,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            x:Name="HideButton"
                            Style="{StaticResource CaptionButton}"
                            Content="&#xE70D;"
                            ToolTip="Hide to tray (Ctrl+Shift+M to reopen)"
                            Click="Hide_Click" />
                </Grid>
            </Border>

            <Rectangle Height="1" Fill="{StaticResource HairlineBrush}" />

            <!-- ═══════ Content ═══════ -->
            <StackPanel Margin="18,16,18,16">

                <!-- Update banner — shown when a newer release is available. -->
                <Border x:Name="UpdateBanner"
                        Visibility="Collapsed"
                        Background="#332E7DFF"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,10"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="UpdateBannerTitle"
                                       Text="Update available"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="11"
                                       Margin="0,3,0,0">
                                <Hyperlink x:Name="UpdateBannerLink"
                                           Click="UpdateBannerLink_Click"
                                           Foreground="{StaticResource AccentHoverBrush}"
                                           TextDecorations="{x:Null}">View release on GitHub</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource CaptionButton}"
                                Content="&#xE711;"
                                VerticalAlignment="Top"
                                ToolTip="Dismiss"
                                Click="UpdateBannerDismiss_Click" />
                    </Grid>
                </Border>

                <!-- Live arrangement map — monitors drawn to scale, populated
                     in code-behind. Click a monitor to make it primary. -->
                <Border x:Name="MapHost"
                        Background="{StaticResource MapSurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <Canvas x:Name="ArrangementCanvas" Height="104" ClipToBounds="False" />
                </Border>

                <TextBlock Text="DISPLAYS"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="10.5" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="2,0,0,10" />

                <!-- Monitor cards (populated in code-behind) -->
                <StackPanel x:Name="MonitorList" />

                <Border x:Name="EmptyStateHost"
                        Visibility="Collapsed"
                        Background="{StaticResource MapSurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,4">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE7F4;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="28"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="EmptyStateTitle"
                                   Text="Only one monitor connected"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="EmptyState"
                                   Text="Connect another display to swap or change primary."
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="11.5"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Button x:Name="SwapButton"
                        Style="{StaticResource SwapButton}"
                        Margin="0,10,0,0"
                        Click="Swap_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SwapIcon"
                                   Text="&#xE895;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,9,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SwapIconRotate" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="SwapLabel"
                                   Text="Swap Displays"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280" />
                    </StackPanel>
                </Button>

                <!-- Auto-swap profiles — summary + link to Settings -->
                <Button x:Name="ProfilesCard"
                        Style="{StaticResource MonitorCard}"
                        Margin="0,14,0,0"
                        Click="ProfilesCard_Click">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="32" Height="32"
                                CornerRadius="8"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#334F8DFF" Offset="0" />
                                    <GradientStop Color="#339D6BFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE7FC;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="15"
                                       Foreground="{StaticResource AccentHoverBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Auto-swap profiles"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="ProfilesSummaryText"
                                       Text="Add a game profile"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   x:Name="ProfilesManageHint"
                                   Text="Add ›"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentHoverBrush}" />
                    </Grid>
                </Button>

                <!-- Start with Windows -->
                <Grid Margin="2,18,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Start with Windows"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="12.5"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <ToggleButton x:Name="StartupToggle"
                                  Grid.Column="1"
                                  Style="{StaticResource ToggleSwitch}"
                                  Checked="StartupToggle_Changed"
                                  Unchecked="StartupToggle_Changed" />
                </Grid>

                <!-- Status line -->
                <TextBlock x:Name="StatusText"
                           Text=""
                           FontFamily="{StaticResource UiFont}"
                           FontSize="11.5"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="2,14,2,0" />

                <TextBlock FontFamily="{StaticResource UiFont}"
                           FontSize="10.5"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="2,12,2,0">
                    <Hyperlink Click="Settings_Click"
                               Foreground="{StaticResource AccentBrush}"
                               TextDecorations="{x:Null}">Settings</Hyperlink>
                    <Run Text="  ·  " />
                    <Hyperlink Click="ViewLog_Click"
                               Foreground="{StaticResource AccentBrush}"
                               TextDecorations="{x:Null}">Activity log</Hyperlink>
                </TextBlock>

                <TextBlock FontFamily="{StaticResource UiFont}"
                           FontSize="10.5"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="2,8,2,0">
                    <Run Text="By Sohiab Rehman · " />
                    <Hyperlink Click="HelpEmail_Click"
                               Foreground="{StaticResource AccentBrush}"
                               TextDecorations="{x:Null}">
                        Help
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
