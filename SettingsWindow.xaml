<Window x:Class="PrimaryDisplaySwap.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot — Settings"
        Width="560"
        Height="720"
        MinWidth="520"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="StatusText"
                           FontSize="11"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="16,12,16,8">
        <StackPanel>

            <!-- ═══════ Hotkeys ═══════ -->
            <TextBlock Text="HOTKEYS"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="2,0,0,8" />

            <Border Background="{StaticResource MapSurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,14">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Open control panel"
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Global shortcut to show the flyout"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Button x:Name="OpenPanelCapture" Grid.Column="1"
                                Style="{StaticResource MiniButton}"
                                MinWidth="150"
                                Click="CaptureOpenPanel_Click" />
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource HairlineBrush}" Margin="0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <CheckBox x:Name="CycleEnabledCheck"
                                      Style="{StaticResource DarkCheckBox}"
                                      Content="Cycle primary display"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Checked="CycleEnabled_Changed"
                                      Unchecked="CycleEnabled_Changed" />
                            <TextBlock Text="Optional shortcut to rotate the primary monitor"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="27,2,0,0" />
                        </StackPanel>
                        <Button x:Name="CycleCapture" Grid.Column="1"
                                Style="{StaticResource MiniButton}"
                                MinWidth="150"
                                Click="CaptureCycle_Click" />
                    </Grid>

                    <TextBlock x:Name="CaptureHint"
                               Text=""
                               FontSize="11"
                               Foreground="{StaticResource AccentHoverBrush}"
                               Margin="0,10,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- ═══════ Auto-swap profiles link ═══════ -->
            <TextBlock Text="AUTO-SWAP PROFILES"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="2,0,0,8" />

            <Border Background="{StaticResource MapSurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Game profiles"
                                   FontSize="12.5"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Add, edit, or remove auto-swap rules in the profile manager."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Open profile manager"
                            Style="{StaticResource AccentMiniButton}"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="OpenProfileManager_Click" />
                </Grid>
            </Border>

            <TextBlock Text="BACKUP &amp; RESTORE"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="2,0,0,8" />

            <Border Background="{StaticResource MapSurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Export or import your settings file (hotkeys, profiles, nicknames). Import replaces all settings after confirmation; a backup of the current file is saved first."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ExportSettingsButton" Content="Export settings"
                                Style="{StaticResource MiniButton}" Width="130"
                                Click="ExportSettings_Click" />
                        <Button x:Name="ImportSettingsButton" Content="Import settings"
                                Style="{StaticResource MiniButton}" Width="130"
                                Margin="8,0,0,0"
                                Click="ImportSettings_Click" />
                    </StackPanel>
                    <Button x:Name="RunWizardButton" Content="Run setup wizard again"
                            Style="{StaticResource MiniButton}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"
                            Click="RunWizard_Click" />
                    <Rectangle Height="1" Fill="{StaticResource HairlineBrush}" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- ═══════ Appearance ═══════ -->
            <TextBlock Text="APPEARANCE"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="2,12,0,8" />

            <Border Background="{StaticResource MapSurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Theme"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="System follows your Windows light/dark setting and accent colour."
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,2,12,0" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeCombo"
                              Grid.Column="1"
                              Style="{StaticResource DarkComboBox}"
                              Width="130"
                              VerticalAlignment="Center"
                              SelectionChanged="Theme_Changed">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Dark" />
                        <ComboBoxItem Content="Light" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- ═══════ Updates ═══════ -->
            <TextBlock Text="UPDATES"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="2,12,0,8" />

            <Border Background="{StaticResource MapSurfaceBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,0">
                <StackPanel>
                    <CheckBox x:Name="AutoUpdateCheck"
                              Style="{StaticResource DarkCheckBox}"
                              Content="Check GitHub for updates on startup"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Checked="AutoUpdate_Changed"
                              Unchecked="AutoUpdate_Changed" />
                    <TextBlock Text="Telemetry-free: queries only the public GitHub releases API."
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="27,2,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="CheckNowButton" Content="Check now"
                                Style="{StaticResource MiniButton}" Width="120"
                                Click="CheckNow_Click" />
                        <TextBlock x:Name="UpdateStatusText"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="16,14,16,16"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="Close" Style="{StaticResource AccentMiniButton}"
                    Height="38" HorizontalAlignment="Right" Width="120"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
