<Window x:Class="PrimaryDisplaySwap.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot — Settings"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder" Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="StatusText"
                           MinHeight="16"
                           FontSize="11"
                           Margin="0,3,0,0"
                           Foreground="{StaticResource TextMutedBrush}"
                           AutomationProperties.LiveSetting="Polite" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="156" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar navigation. One page visible at a time; pages never
                 dictate window height, which eliminates the fit-to-content
                 sizing bugs of the old single-scroll layout. -->
            <ListBox x:Name="NavList"
                     Grid.Column="0"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectedIndex="0"
                     SelectionChanged="Nav_Changed"
                     KeyboardNavigation.DirectionalNavigation="Cycle">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,9" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="FontSize" Value="12.5" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background"
                                                    Value="{StaticResource MapSurfaceBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background"
                                                    Value="{StaticResource MapSurfaceBrush}" />
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextPrimaryBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Content="General" />
                <ListBoxItem Content="Shortcuts" />
                <ListBoxItem Content="Displays" />
                <ListBoxItem Content="Automation" />
                <ListBoxItem Content="Data &amp; support" />
            </ListBox>

            <Grid Grid.Column="1" Margin="14,0,0,0">

            <ScrollViewer x:Name="PageGeneral"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,2,0,4">
                        <TextBlock Text="STARTUP"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <CheckBox x:Name="StartupCheck"
                                          Style="{StaticResource DarkCheckBox}"
                                          Content="Start DisplayPilot with Windows"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          AutomationProperties.HelpText="Starts DisplayPilot hidden in the notification area when you sign in."
                                          Checked="Startup_Changed"
                                          Unchecked="Startup_Changed" />
                                <TextBlock Text="Starts hidden in the notification area when you sign in."
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="27,2,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="APPEARANCE"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Theme" FontSize="12.5"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="System follows the Windows app theme and accent colour."
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,2,12,0" />
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeCombo" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="135" VerticalAlignment="Center"
                                              AutomationProperties.Name="Theme"
                                              SelectionChanged="Theme_Changed">
                                        <ComboBoxItem Content="System" />
                                        <ComboBoxItem Content="Dark" />
                                        <ComboBoxItem Content="Light" />
                                    </ComboBox>
                                </Grid>
                                <CheckBox x:Name="CompactTrayMenuCheck"
                                          Style="{StaticResource DarkCheckBox}"
                                          Content="Compact tray menu"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,14,0,0"
                                          AutomationProperties.HelpText="Shorter tray menu with nickname-only display lines and nested Auto-swap controls. Turn off for the denser power-user layout."
                                          Checked="CompactTrayMenu_Changed"
                                          Unchecked="CompactTrayMenu_Changed" />
                                <TextBlock Text="Shorter tray menu by default. Turn off to restore full display specs and the denser layout."
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="27,2,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="UPDATES"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12">
                            <StackPanel>
                                <CheckBox x:Name="AutoUpdateCheck"
                                          Style="{StaticResource DarkCheckBox}"
                                          Content="Check GitHub for updates on startup"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Checked="AutoUpdate_Changed"
                                          Unchecked="AutoUpdate_Changed" />
                                <TextBlock Text="Telemetry-free: queries only the public GitHub releases API."
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="27,2,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="CheckNowButton" Content="Check now"
                                            Style="{StaticResource MiniButton}" Width="110"
                                            AutomationProperties.Name="Check for updates now"
                                            Click="CheckNow_Click" />
                                    <Button x:Name="OpenUpdateButton" Content="Open release"
                                            Style="{StaticResource AccentMiniButton}" Width="110"
                                            Margin="8,0,0,0" Visibility="Collapsed"
                                            Click="OpenUpdate_Click" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               FontSize="11.5" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               AutomationProperties.LiveSetting="Polite" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PageShortcuts"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,2,0,4">
                        <TextBlock Text="GLOBAL SHORTCUTS"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Open control panel" FontSize="12.5"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="Shows the flyout from anywhere."
                                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button x:Name="OpenPanelCapture" Grid.Column="1"
                                            Style="{StaticResource MiniButton}" MinWidth="150"
                                            AutomationProperties.Name="Change open control panel shortcut"
                                            Click="CaptureOpenPanel_Click" />
                                </Grid>

                                <Rectangle Height="1" Fill="{StaticResource HairlineBrush}" Margin="0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <CheckBox x:Name="CycleEnabledCheck"
                                                  Style="{StaticResource DarkCheckBox}"
                                                  Content="Cycle primary display"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Checked="CycleEnabled_Changed"
                                                  Unchecked="CycleEnabled_Changed" />
                                        <TextBlock Text="Rotates the primary monitor in Windows display order."
                                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="27,2,0,0" />
                                    </StackPanel>
                                    <Button x:Name="CycleCapture" Grid.Column="1"
                                            Style="{StaticResource MiniButton}" MinWidth="150"
                                            AutomationProperties.Name="Change cycle primary display shortcut"
                                            Click="CaptureCycle_Click" />
                                </Grid>

                                <TextBlock x:Name="CaptureHint"
                                           MinHeight="16" FontSize="11"
                                           Foreground="{StaticResource AccentHoverBrush}"
                                           Margin="0,10,0,0"
                                           Visibility="Collapsed"
                                           AutomationProperties.LiveSetting="Assertive" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PageDisplays"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,2,0,4">
                    <Grid Margin="2,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CONNECTED DISPLAYS"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <Button Grid.Column="1" Content="Refresh"
                                Style="{StaticResource MiniButton}" Width="80"
                                Margin="0,0,2,0"
                                Click="RefreshDisplays_Click" />
                    </Grid>
                    <StackPanel x:Name="DisplaysPanel" />
                    <TextBlock Text="Nicknames appear everywhere DisplayPilot shows a monitor. HDR is shown only for displays that support it."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,4,0,0" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PageAutomation"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,2,0,4">
                        <TextBlock Text="AUTO-SWAP PROFILES"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Game and app profiles" FontSize="12.5"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Choose which monitor wins when apps overlap, manage priorities, and capture display scenes."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,2,12,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open profile manager"
                                        Style="{StaticResource AccentMiniButton}"
                                        VerticalAlignment="Center" Padding="14,6"
                                        AutomationProperties.Name="Open profile and display scene manager"
                                        Click="OpenProfileManager_Click" />
                            </Grid>
                        </Border>
                    </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PageSupport"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,2,0,4">
                        <TextBlock Text="BACKUP &amp; RESTORE"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Export or replace all DisplayPilot settings, including shortcuts, profiles, display scenes, nicknames, theme, and update preferences. A backup is created before import."
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="ExportSettingsButton" Content="Export settings"
                                            Style="{StaticResource MiniButton}" Width="130"
                                            Click="ExportSettings_Click" />
                                    <Button x:Name="ImportSettingsButton" Content="Import settings"
                                            Style="{StaticResource MiniButton}" Width="130"
                                            Margin="8,0,0,0" Click="ImportSettings_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="SUPPORT"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,8" />
                        <Border Background="{StaticResource MapSurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,12">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="RunWizardButton" Content="Run setup wizard"
                                        Style="{StaticResource MiniButton}" Width="140"
                                        Click="RunWizard_Click" />
                                <Button Content="Open activity log"
                                        Style="{StaticResource MiniButton}" Width="140"
                                        Margin="8,0,0,0" Click="OpenLog_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
            </ScrollViewer>

            </Grid>
        </Grid>

        <Border x:Name="FooterBorder" Grid.Row="2" Padding="16,12,16,14"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="Close" Style="{StaticResource AccentMiniButton}"
                    Height="38" HorizontalAlignment="Right" Width="120"
                    IsCancel="True" AutomationProperties.Name="Close settings"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
