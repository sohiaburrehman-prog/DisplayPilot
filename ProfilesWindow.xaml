<Window x:Class="PrimaryDisplaySwap.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot — Profiles &amp; layouts"
        Width="600"
        Height="680"
        MinWidth="560"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Profiles &amp; layout presets"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="StatusText"
                               FontSize="11"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
                <Button x:Name="AddProfileButton" Grid.Column="1"
                        Style="{StaticResource MiniButton}"
                        Content="+ Add profile"
                        VerticalAlignment="Center"
                        Click="AddProfile_Click" />
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="16,12,16,8"
                    Background="Transparent" BorderThickness="0">
            <TabItem Header="Auto-swap profiles">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ListHintText"
                               Grid.Row="0"
                               Text="When profiles overlap, the winning profile controls the primary display. When it exits, the next active profile resumes; the final winner can restore the original primary."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,0,0,10" />

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="When profiles overlap:"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,10,0" />
                        <ComboBox x:Name="ConflictRuleCombo"
                                  Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="ConflictRule_Changed">
                            <ComboBoxItem Content="Highest priority wins (newest breaks ties)" Tag="HighestPriority" />
                            <ComboBoxItem Content="Most recently activated wins" Tag="MostRecentlyActivated" />
                        </ComboBox>
                    </Grid>

                    <TextBox x:Name="SearchBox"
                             Grid.Row="2"
                             Margin="0,0,0,10"
                             Padding="10,8"
                             FontSize="12"
                             Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource HairlineBrush}"
                             TextChanged="SearchBox_TextChanged" />

                    <ScrollViewer x:Name="ProfilesScroll"
                                  Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel x:Name="ProfileListPanel" />

                            <TextBlock x:Name="NoProfilesText"
                                       Text="No profiles yet. Add one to auto-swap your primary monitor when a game or launcher starts."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8" />

                            <TextBlock x:Name="NoSearchResultsText"
                                       Text="No profiles match your search."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8"
                                       Visibility="Collapsed" />

                            <Button x:Name="EmptyAddButton"
                                    Style="{StaticResource AccentMiniButton}"
                                    Content="+ Add profile"
                                    HorizontalAlignment="Left"
                                    Width="140"
                                    Margin="0,0,0,8"
                                    Click="AddProfile_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="ProfileEditorPanel"
                            Grid.Row="3"
                            Visibility="Collapsed"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12" />
                </Grid>
            </TabItem>

            <TabItem Header="Layout presets">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Save your current primary monitor and per-display resolution/refresh. Apply a preset to switch layouts in one click."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,0,0,10" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="NewPresetNameBox"
                                 Width="220"
                                 Padding="10,8"
                                 FontSize="12"
                                 Background="{StaticResource CardBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource HairlineBrush}"
                                 Text="My layout" />
                        <Button Style="{StaticResource AccentMiniButton}"
                                Content="Save current layout"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Click="SavePreset_Click" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel x:Name="PresetListPanel" />
                            <TextBlock x:Name="NoPresetsText"
                                       Text="No layout presets yet. Save your current monitor arrangement above."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Padding="16,14,16,16"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="Close" Style="{StaticResource AccentMiniButton}"
                    Height="38" HorizontalAlignment="Right" Width="120"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
