<Window x:Class="PrimaryDisplaySwap.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot — Profiles &amp; display scenes"
        Width="680"
        Height="720"
        MinWidth="600"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Profiles &amp; display scenes"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="StatusText"
                               MinHeight="16"
                               FontSize="11"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ExplainStateButton"
                            Style="{StaticResource MiniButton}"
                            Content="Explain profiles"
                            AutomationProperties.Name="Explain profile matching and winner"
                            Margin="0,0,8,0"
                            Click="ShowDiagnostics_Click" />
                    <Button x:Name="AddProfileButton"
                            Style="{StaticResource MiniButton}"
                            Content="+ Add profile"
                            AutomationProperties.Name="Add auto-swap profile"
                            Click="AddProfile_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="16,12,16,8"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Style="{StaticResource FlyoutTabControl}">
            <TabItem Header="Profiles">
                <Grid Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ListHintText"
                               Grid.Row="0"
                               Text="Profiles switch the primary display when an app runs. A matched profile can wait behind a higher-priority winner."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,0,0,10" />

                    <Grid x:Name="ConflictRulePanel" Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="When profiles overlap:"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,10,0" />
                        <ComboBox x:Name="ConflictRuleCombo"
                                  Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="ConflictRule_Changed">
                            <ComboBoxItem Content="Highest priority wins (newest breaks ties)" Tag="HighestPriority" />
                            <ComboBoxItem Content="Most recently activated wins" Tag="MostRecentlyActivated" />
                        </ComboBox>
                    </Grid>

                    <Grid x:Name="SearchPanel" Grid.Row="2" Margin="0,0,0,10">
                        <TextBox x:Name="SearchBox"
                                 Padding="10,8"
                                 FontSize="12"
                                 Background="{StaticResource CardBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource HairlineBrush}"
                                 AutomationProperties.Name="Search profiles"
                                 TextChanged="SearchBox_TextChanged" />
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="Search profiles…"
                                   Margin="11,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Grid>

                    <ScrollViewer x:Name="ProfilesScroll"
                                  Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel x:Name="ProfileListPanel" />

                            <TextBlock x:Name="NoProfilesText"
                                       Text="No profiles yet. Add one to auto-swap your primary monitor when a game or launcher starts."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8" />

                            <TextBlock x:Name="NoSearchResultsText"
                                       Text="No profiles match your search."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8"
                                       Visibility="Collapsed" />

                            <Button x:Name="EmptyAddButton"
                                    Style="{StaticResource AccentMiniButton}"
                                    Content="+ Add profile"
                                    HorizontalAlignment="Left"
                                    Width="140"
                                    Margin="0,0,0,8"
                                    Click="AddProfile_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="ProfileEditorPanel"
                            Grid.Row="3"
                            Visibility="Collapsed"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12">
                        <ScrollViewer x:Name="ProfileEditorScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Display scenes">
                <Grid Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Scenes capture the primary monitor, resolution, refresh rate, desktop position, rotation, and HDR for every active display. Windows display scaling is not changed."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,0,0,10" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="NewPresetNameBox"
                                 Width="220"
                                 Padding="10,8"
                                 FontSize="12"
                                 Background="{StaticResource CardBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource HairlineBrush}"
                                 Text="My layout" />
                        <Button x:Name="SavePresetButton"
                                Style="{StaticResource AccentMiniButton}"
                                Content="Capture current scene"
                                Margin="10,0,0,0"
                                Padding="12,8"
                                Click="SavePreset_Click" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel x:Name="PresetListPanel" />
                            <TextBlock x:Name="NoPresetsText"
                                       Text="No display scenes yet. Capture the current monitor arrangement above."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="2,2,0,8" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Padding="16,14,16,16"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="Close" Style="{StaticResource AccentMiniButton}"
                    Height="38" HorizontalAlignment="Right" Width="120"
                    IsCancel="True" AutomationProperties.Name="Close profile manager"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
