<Window x:Class="PrimaryDisplaySwap.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DisplayPilot — Activity log"
        Width="640"
        Height="560"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FlyoutOpaqueBrush}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <TextBlock Text="Activity log"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="PathText"
                           FontSize="11"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,12,16,0"
                Background="{StaticResource MapSurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer x:Name="LogScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="14,12">
                <TextBox x:Name="LogText"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="11.5"
                         TextWrapping="NoWrap" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Padding="16,14,16,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Refresh" Style="{StaticResource MiniButton}"
                        Width="92" Click="Refresh_Click" />
                <Button Grid.Column="1" Content="Copy log" Style="{StaticResource MiniButton}"
                        Width="92" Margin="8,0,0,0" Click="Copy_Click" />
                <Button Grid.Column="2" Content="Open log folder" Style="{StaticResource MiniButton}"
                        Width="130" Margin="8,0,0,0" Click="OpenFolder_Click" />
                <Button Grid.Column="4" Content="Close" Style="{StaticResource AccentMiniButton}"
                        Width="92" Click="Close_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
